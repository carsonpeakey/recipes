---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary?: string;
  version?: string;
  tags?: string[];
  slug?: string;
  heroImage?: ImageMetadata;
}

const { title, summary, version, tags = [], slug, heroImage } = Astro.props;

// Try to load placeholder image if no hero provided
let displayImage = heroImage;
if (!displayImage && slug) {
  try {
    const placeholders = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/placeholders/*.png');
    const key = `/src/assets/images/placeholders/${slug}.png`;
    if (placeholders[key]) {
      const mod = await placeholders[key]();
      displayImage = mod.default;
    }
  } catch {
    // No placeholder available — that's fine
  }
}
---

<BaseLayout title={title}>
  <div class="single">
    <div class="border-4 rounded-lg p-4 my-4" style={`border-color: var(--color-ocean-light); background: var(--color-ocean)`}>
      {displayImage && (
        <Image src={displayImage} alt={title} class="w-full rounded-lg mb-2" width={400} height={300} />
      )}
      <h2 class="text-2xl" style={`color: var(--color-sky-light)`}>{title}</h2>
      {summary && <p style={`color: var(--color-sky-light)`}>{summary}</p>}
      {version && <span class="inline-block text-xs px-2 py-0.5 rounded" style={`background: var(--color-ocean-light); color: var(--color-sky-light)`}>{version}</span>}
    </div>

    <slot />

    {tags.length > 0 && (
      <div class="mt-4">
        <span>Tags:</span>
        <ul class="flex gap-2 list-none ml-0">
          {tags.map((tag: string) => (
            <li class="pb-0">
              <a href={`/tags/${tag}/`} class="px-2 py-1 rounded text-sm" style={`background: var(--color-ocean); color: var(--color-sky-light)`}>{tag}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</BaseLayout>
