---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary?: string;
  version?: string;
  tags?: string[];
  slug?: string;
  heroImage?: ImageMetadata;
}

const { title, summary, version, tags = [], slug, heroImage } = Astro.props;

// Try to load placeholder image if no hero provided
let displayImage = heroImage;
if (!displayImage && slug) {
  try {
    const placeholders = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/placeholders/*.png');
    const key = `/src/assets/images/placeholders/${slug}.png`;
    if (placeholders[key]) {
      const mod = await placeholders[key]();
      displayImage = mod.default;
    }
  } catch {
    // No placeholder available — that's fine
  }
}
---

<BaseLayout title={title}>
  <div class="single">
    <div class="mb-6">
      {displayImage && (
        <div class="hero-strip">
          <Image src={displayImage} alt={title} class="hero-img" width={800} height={400} />
        </div>
      )}
      <h1 style={`color: var(--color-sky)`}>{title}</h1>
      {summary && <p class="mt-1" style={`color: var(--color-black-light)`}>{summary}</p>}
      {version && <span class="inline-block text-xs mt-1" style={`color: var(--color-black-light)`}>{version}</span>}
    </div>

    <slot />

    {tags.length > 0 && (
      <div class="mt-6 pt-4" style="border-top: 1px solid rgba(224,251,252,0.1)">
        <ul class="flex gap-2 list-none ml-0 flex-wrap">
          {tags.map((tag: string) => (
            <li class="pb-0">
              <a href={`/tags/${tag}/`} class="px-3 py-1 rounded text-sm" style={`background: rgba(61,90,128,0.3); color: var(--color-sky-light); text-decoration: none`}>{tag}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .hero-strip {
    width: 100%;
    height: 8rem;
    overflow: hidden;
    border-radius: 0.375rem;
    margin-bottom: 0.75rem;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.8;
  }
</style>
