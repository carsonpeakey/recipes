---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const siteTitle = 'Recipe Box';
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <title>{pageTitle}</title>
</head>
<body>
  <header>
    <nav class="flex items-center justify-between mb-6 pb-2" style="border-bottom: 1px solid rgba(224,251,252,0.1)">
      <a href="/" class="text-xl font-semibold" style={`color: var(--color-sky-light); text-decoration: none`}>{siteTitle}</a>
      <div class="flex gap-4 text-sm">
        <a href="/recipes/">Recipes</a>
        <a href="/techniques/">Techniques</a>
      </div>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer class="mt-12 pt-4 pb-8 text-center text-sm" style={`border-top: 1px solid rgba(224,251,252,0.1); color: var(--color-black-light)`}>
    <p>A collection of recipes we want to remember and share. Sources provided.</p>
    <div class="flex justify-center gap-2 my-2">
      <img src="https://mirrors.creativecommons.org/presskit/icons/cc.svg?ref=chooser-v1" alt="CC" class="h-5 opacity-50" />
      <img src="https://mirrors.creativecommons.org/presskit/icons/by.svg?ref=chooser-v1" alt="CC BY" class="h-5 opacity-50" />
    </div>
  </footer>
</body>
</html>
