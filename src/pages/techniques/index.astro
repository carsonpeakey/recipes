---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const techniques = await getCollection('techniques');
---

<BaseLayout title="Techniques">
  <h1>Techniques</h1>
  {techniques.map((technique) => (
    <div class="py-3" style="border-bottom: 1px solid rgba(224,251,252,0.08)">
      <a href={`/techniques/${technique.id}/`} class="text-lg">{technique.data.title}</a>
      {technique.data.summary && <p class="text-sm mt-0.5" style={`color: var(--color-black-light)`}>{technique.data.summary}</p>}
    </div>
  ))}
</BaseLayout>
