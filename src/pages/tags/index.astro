---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const recipes = await getCollection('recipes');
const techniques = await getCollection('techniques');
const allContent = [...recipes.filter((r) => !r.id.startsWith('_')), ...techniques];

const tagCounts = new Map<string, number>();
allContent.forEach((item) =>
  item.data.tags?.forEach((tag: string) => tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1))
);

const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags">
  <h1>Tags</h1>
  {sortedTags.length === 0 && <p style={`color: var(--color-black-light)`}>No tags yet.</p>}
  <div class="flex flex-wrap gap-2 mt-4">
    {sortedTags.map(([tag, count]) => (
      <a href={`/tags/${tag}/`} class="px-2 py-0.5 rounded text-sm" style={`background: rgba(61,90,128,0.3); color: var(--color-sky-light); text-decoration: none`}>
        {tag} ({count})
      </a>
    ))}
  </div>
</BaseLayout>
