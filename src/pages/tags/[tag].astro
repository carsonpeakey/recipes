---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  const techniques = await getCollection('techniques');
  const allContent = [...recipes.filter((r) => !r.id.startsWith('_')), ...techniques];

  const tags = new Set<string>();
  allContent.forEach((item) => item.data.tags?.forEach((tag: string) => tags.add(tag)));

  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: {
      tag,
      items: allContent.filter((item) => item.data.tags?.includes(tag)),
    },
  }));
}

const { tag, items } = Astro.props;
---

<BaseLayout title={`Tag: ${tag}`}>
  <h1>Tag: {tag}</h1>
  {items.map((item: any) => {
    const collection = item.collection || 'recipes';
    return (
      <div class="py-3" style="border-bottom: 1px solid rgba(224,251,252,0.08)">
        <a href={`/${collection}/${item.id}/`} class="text-lg">{item.data.title}</a>
        {item.data.summary && <p class="text-sm mt-0.5" style={`color: var(--color-black-light)`}>{item.data.summary}</p>}
      </div>
    );
  })}
</BaseLayout>
