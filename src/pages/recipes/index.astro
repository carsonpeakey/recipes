---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const recipes = (await getCollection('recipes')).filter((r) => !r.id.startsWith('_'));
---

<BaseLayout title="Recipes">
  <h1>Recipes</h1>
  {recipes.map((recipe) => (
    <div class="py-3" style="border-bottom: 1px solid rgba(224,251,252,0.08)">
      <a href={`/recipes/${recipe.id}/`} class="text-lg">{recipe.data.title}</a>
      {recipe.data.summary && <p class="text-sm mt-0.5" style={`color: var(--color-black-light)`}>{recipe.data.summary}</p>}
    </div>
  ))}
</BaseLayout>
